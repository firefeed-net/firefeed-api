# FireFeed API Environment Configuration
# Copy to .env and replace dummy tokens with generated ones from tools/generate_service_token.py

# Database (docker-compose overrides)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=firefeed
DB_USER=firefeed_api
DB_PASSWORD=firefeed_password

# Redis (docker-compose overrides)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=firefeed_redis_pass

# JWT/Auth
JWT_SECRET=public-api-secret
JWT_ALGORITHM=HS256

# FireFeed API
SERVICE_API_TOKEN=token_here

# API Config
API_BASE_URL=http://localhost:8001

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

