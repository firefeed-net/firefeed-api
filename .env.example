# Database Configuration
POSTGRES_PASSWORD=your_postgres_password_here
FIREFEED_DB=firefeed
FIREFEED_DB_USER=firefeed_api
FIREFEED_DB_PASSWORD=your_db_password_here
FIREFEED_API_DB_USER=firefeed_api
FIREFEED_API_DB_PASSWORD=your_api_db_password_here

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_URL=postgresql://${FIREFEED_DB_USER}:${FIREFEED_DB_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${FIREFEED_DB}

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_SSL=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_ENVIRONMENT=development
API_DEBUG=true
API_LOG_LEVEL=debug
API_ACCESS_LOG=true

# Security Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Cache Configuration
API_CACHE_TTL=3600
API_SESSION_TTL=86400
API_RATE_LIMIT_TTL=3600
API_CACHE_PREFIX=api:cache
API_SESSION_PREFIX=api:session
API_RATE_LIMIT_PREFIX=api:rate_limit

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# External API Keys
OPENAI_API_KEY=your-openai-api-key
YANDEX_API_KEY=your-yandex-api-key
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key
FIREFEED_API_TOKEN=your_firefeed_api_token_here

# Monitoring and Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/firefeed-api.log

# Development Settings
DEBUG_TOOLBAR=false
HOT_RELOAD=true
ENVIRONMENT=development
DEBUG=true

# Feature Flags
TRANSLATION_ENABLED=true
DUPLICATE_DETECTION_ENABLED=true
CACHE_ENABLED=true
RATE_LIMIT_ENABLED=true

# Monitoring
MONITORING_ENABLED=true
PROMETHEUS_ENABLED=true
