# FireFeed API Environment Configuration
# This file is used for local development (outside Docker).
# In Docker, environment variables are injected by docker-compose from root .env.

# JWT/Auth - REQUIRED for local development
FIREFEED_JWT_SECRET_KEY=your-secret-key-min-32-chars-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# Logging
LOG_LEVEL=INFO
