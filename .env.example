# FireFeed API Environment Configuration
# Copy to .env and replace example values with actual ones

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=firefeed
DB_USER=firefeed_api
DB_PASSWORD=firefeed_password_example

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=firefeed_redis_pass_example

# JWT/Auth
# JWT Secret Key - REQUIRED for service token verification (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here
FIREFEED_JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256

# FireFeed API - service token (generate with tools/generate_service_token.py)
SERVICE_API_TOKEN=your_generated_token_here

# API Config
API_BASE_URL=http://localhost:8001

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# Feature flags
TRANSLATION_ENABLED=true
CACHE_ENABLED=true
DUPLICATE_DETECTION_ENABLED=true
